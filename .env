# -----------------------------------------------------------------------------
# MySQL（docker compose / 后端数据库）
# -----------------------------------------------------------------------------
MYSQL_DATABASE=light-oss
MYSQL_USER=root
MYSQL_PASSWORD=112233ss
MYSQL_ROOT_PASSWORD=112233ss

# -----------------------------------------------------------------------------
# Backend 服务配置（APP_*）
# -----------------------------------------------------------------------------
APP_ENV=development
APP_ADDR=:8080
APP_PUBLIC_BASE_URL=http://localhost:8080

# Windows 本地开发默认存储目录；容器环境会使用 volume 挂载目录
APP_STORAGE_ROOT=\light-oss-data\storage

# 上传与请求限制
APP_MAX_UPLOAD_SIZE_BYTES=52428800
APP_MAX_MULTIPART_MEMORY_BYTES=8388608
APP_RATE_LIMIT_RPS=5
APP_RATE_LIMIT_BURST=10

# 允许跨域的前端来源，多个来源用英文逗号分隔
# 本地联调远端后端时，记得把 http://localhost:3000 加进去
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# 认证与签名
APP_BEARER_TOKENS=dev-token
APP_SIGNING_SECRET=change-me-in-local-dev
APP_DEFAULT_SIGNED_URL_TTL_SECONDS=300
APP_MAX_SIGNED_URL_TTL_SECONDS=86400

# HTTP 服务超时
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_SHUTDOWN_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Backend 数据库连接（DB_*）
# -----------------------------------------------------------------------------
DB_DSN=root:112233ss@tcp(localhost:3306)/light-oss?charset=utf8mb4&parseTime=True&loc=UTC&multiStatements=true
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=30

# -----------------------------------------------------------------------------
# Frontend 默认配置（VITE_*）
# 仅作为前端初始值，用户仍可在“设置”页覆盖并保存到 localStorage
# -----------------------------------------------------------------------------
VITE_DEFAULT_API_BASE_URL=http://localhost:8080
VITE_DEFAULT_BEARER_TOKEN=dev-token
